{
  "servers": {
    "asset-aware-mcp": {
      "type": "stdio",
      "command": "/home/eric/.local/bin/uv",
      "args": [
        "tool",
        "run",
        "--python",
        "3.11",
        "--upgrade",
        "--from",
        "asset-aware-mcp==0.6.31",
        "asset-aware-mcp"
      ],
      "env": {
        "LLM_BACKEND": "ollama",
        "OLLAMA_HOST": "http://localhost:11434",
        "OLLAMA_MODEL": "qwen2.5:7b",
        "OLLAMA_EMBEDDING_MODEL": "nomic-embed-text",
        "ENABLE_LIGHTRAG": "true",
        "DATA_DIR": "/home/eric/workspace260420/anesthesia-exam/data",
        "UV_CACHE_DIR": "/home/eric/workspace260420/anesthesia-exam/data/.uv-cache",
        "ASSET_AWARE_SUPPRESS_MARKER_OUTPUT": "true",
        "ASSET_AWARE_MARKER_OUTPUT_LOG": "/home/eric/workspace260420/anesthesia-exam/data/logs/marker.log"
      }
    }
  }
}
