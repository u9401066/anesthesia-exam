# 環境變數範例
# 複製此檔案為 .env 並填入實際值

# 應用程式設定
APP_NAME=workspace251215
APP_ENV=development
APP_DEBUG=true

# 資料庫設定
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=user
DB_PASSWORD=

# API 金鑰（請勿提交真實金鑰）
API_KEY=
SECRET_KEY=

# 外部服務
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Anesthesia Exam agent provider
# EXAM_AGENT_PROVIDER=codex
# EXAM_OPENAI_API_KEY=
# EXAM_OPENAI_BASE_URL=https://api.openai.com/v1
# EXAM_CODEX_MODEL=gpt-5.3-codex

# Telegram read-only admin entrypoint for OpenClaw/site status
# TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=123456789:replace-with-bot-token
# TELEGRAM_ADMIN_CHAT_IDS=123456789
# TELEGRAM_TIMEOUT_SECONDS=10
# TELEGRAM_POLL_TIMEOUT_SECONDS=30
# TELEGRAM_OPENCLAW_ASK_ENABLED=false

# Browser-visible OpenClaw Gateway URL for the right-side embedded console.
# OPENCLAW_GATEWAY_PUBLIC_URL=http://127.0.0.1:18789/
